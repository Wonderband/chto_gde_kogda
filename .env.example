# Copy this file to .env and fill in your real values
# Single OpenAI API key gives access to ALL services below

VITE_OPENAI_API_KEY=sk-...          # platform.openai.com → API Keys
VITE_VECTOR_STORE_ID=vs_...         # platform.openai.com → Storage → Vector Stores
VITE_GAME_LANGUAGE=ru               # "ru" for Russian, "uk" for Ukrainian
VITE_USE_MOCK=false                 # Set "true" to test UI without real API calls
VITE_PLAYER_NAMES=Андрей,Маша,Иван  # Comma-separated names of players at the table

# Models used (for reference, hardcoded in services/):
#   AI Moderator:  gpt-4o              via Responses API
#   Speech-to-Text: gpt-4o-mini-transcribe  via /v1/audio/transcriptions
#   Text-to-Speech: tts-1, voice: onyx  via /v1/audio/speech
