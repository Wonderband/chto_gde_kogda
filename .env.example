# Copy this file to .env and fill in your real values
# Single OpenAI API key gives access to ALL services below

VITE_OPENAI_API_KEY=sk-...           # platform.openai.com → API Keys
VITE_VECTOR_STORE_ID=vs_...          # platform.openai.com → Storage → Vector Stores
VITE_GAME_LANGUAGE=uk                # "uk" for Ukrainian (default), "ru" for Russian
VITE_USE_MOCK=false                  # Set "true" to test UI without real API calls
VITE_PLAYER_NAMES=Андрій,Маша,Іван  # Comma-separated names of players at the table

# Background music: place your MP3 at public/sounds/wheel-music.mp3
# The app silently skips music if the file is absent.

# Game tuning (optional — defaults shown)
VITE_WINNING_SCORE=6                 # Points needed to win
VITE_SPIN_DURATION_MS=17000          # Wheel spin duration in ms (17s fits 5s delay + dialogue + reaction)
VITE_DISCUSSION_SEC=60               # Discussion timer (standard questions)
VITE_BLITZ_SEC=20                    # Discussion timer (blitz questions)

# Model overrides (optional — defaults shown)
# Realtime API: live moderator dialogues (wheel spin banter, warmup, name capture, evaluation ritual)
VITE_REALTIME_MODEL=gpt-4o-mini-realtime-preview  # upgrade to gpt-4o-realtime-preview for less hallucination (10× cost)
VITE_REALTIME_VOICE=cedar                         # cedar / echo / shimmer — cedar is newest and most expressive
# TTS: sector intro, question read, structural cues (black box, item announce, score)
VITE_TTS_MODEL=gpt-4o-mini-tts                    # supports `instructions` field for Ukrainian accent; do NOT downgrade to tts-1
VITE_TTS_VOICE=cedar                              # must match REALTIME_VOICE for consistent timbre
# STT: team answer transcription
VITE_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe      # upgrade to gpt-4o-transcribe for better accuracy on unusual Ukrainian words
# Evaluator: answer judging and explanation text (text-only, no audio)
VITE_EVALUATOR_MODEL=gpt-4.1-mini                 # do NOT downgrade to gpt-4.1-nano — risks wrong verdicts on edge cases
VITE_FAST_EVALUATOR_MODEL=gpt-4.1-mini
# Responses API: used only in mock mode (VITE_USE_MOCK=true)
VITE_RESPONSES_MODEL=gpt-4o
