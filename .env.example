# Copy this file to .env and fill in your real values
# Single OpenAI API key gives access to ALL services below

VITE_OPENAI_API_KEY=sk-...           # platform.openai.com → API Keys
VITE_VECTOR_STORE_ID=vs_...          # platform.openai.com → Storage → Vector Stores
VITE_GAME_LANGUAGE=uk                # "uk" for Ukrainian (default), "ru" for Russian
VITE_USE_MOCK=false                  # Set "true" to test UI without real API calls
VITE_PLAYER_NAMES=Андрій,Маша,Іван  # Comma-separated names of players at the table

# Game tuning (optional — defaults shown)
VITE_WINNING_SCORE=6                 # Points needed to win
VITE_SPIN_DURATION_MS=30000          # Wheel spin duration in milliseconds
VITE_DISCUSSION_SEC=60               # Discussion timer (standard questions)
VITE_BLITZ_SEC=20                    # Discussion timer (blitz questions)

# Model overrides (optional — defaults shown)
VITE_REALTIME_MODEL=gpt-realtime-mini         # Realtime API model (moderator voice)
VITE_REALTIME_VOICE=echo                      # Realtime API voice
VITE_TTS_MODEL=tts-1                          # TTS model (listening cue fallback)
VITE_TTS_VOICE=onyx                           # TTS voice
VITE_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe  # Speech-to-text model
VITE_RESPONSES_MODEL=gpt-4o                   # Responses API model (mock/fallback)
VITE_EVALUATOR_MODEL=gpt-4.1-nano             # Answer evaluator model
VITE_FAST_EVALUATOR_MODEL=gpt-4.1-nano        # Fast evaluator (defaults to EVALUATOR_MODEL)
